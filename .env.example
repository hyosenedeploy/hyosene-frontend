# ── PASTE THESE INTO VERCEL → Settings → Environment Variables ──

# Your Render backend URL (after deploying backend to Render)
NEXT_PUBLIC_BACKEND_URL=https://YOUR-APP-NAME.onrender.com

# Razorpay Key ID (from Razorpay dashboard)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxx
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
